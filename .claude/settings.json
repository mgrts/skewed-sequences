{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(tree:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(sed -n:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git check-ignore:*)",
      "Bash(git stash list:*)",
      "Bash(git config --get:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git tag:*)",
      "Bash(git stash:*)",
      "Bash(poetry run:*)",
      "Bash(poetry install:*)",
      "Bash(poetry env:*)",
      "Bash(poetry show:*)",
      "Bash(poetry lock:*)",
      "Bash(make:*)",
      "Bash(pre-commit run:*)",
      "Bash(pytest:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(skseq:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo view:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.p12)",
      "Read(./**/*.pfx)",
      "Read(./**/id_rsa*)",
      "Read(./**/credentials.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "DIR=\"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}\"; H=\"$DIR/.claude/hooks/guard_git.py\"; [ -f \"$H\" ] || exit 0; PY=\"$DIR/.venv/bin/python\"; [ -x \"$PY\" ] || PY=python3; \"$PY\" \"$H\""
          },
          {
            "type": "command",
            "command": "DIR=\"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}\"; H=\"$DIR/.claude/hooks/block_large_secret.py\"; [ -f \"$H\" ] || exit 0; PY=\"$DIR/.venv/bin/python\"; [ -x \"$PY\" ] || PY=python3; \"$PY\" \"$H\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "DIR=\"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}\"; H=\"$DIR/.claude/hooks/auto_format.py\"; [ -f \"$H\" ] || exit 0; PY=\"$DIR/.venv/bin/python\"; [ -x \"$PY\" ] || PY=python3; \"$PY\" \"$H\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "DIR=\"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}\"; H=\"$DIR/.claude/hooks/run_pytest.py\"; [ -f \"$H\" ] || exit 0; PY=\"$DIR/.venv/bin/python\"; [ -x \"$PY\" ] || PY=python3; \"$PY\" \"$H\""
          }
        ]
      }
    ]
  }
}
